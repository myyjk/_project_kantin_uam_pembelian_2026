# ============================================
# URL REWRITE - _PROJECT_26
# Aktifkan dulu mod_rewrite di XAMPP:
# httpd.conf → uncomment LoadModule rewrite_module
# ============================================

Options -Indexes
RewriteEngine On
RewriteBase /_project_26/

# ── Arahkan URL pendek ke file PHP yang sesuai ──

# /pembeli → /pembeli/pembelian.php
RewriteRule ^pembeli/?$          pembeli/pembelian.php    [L,QSA]

# /transaksi → /transaksi/transaksi.php
RewriteRule ^transaksi/?$        transaksi/transaksi.php  [L,QSA]

# /transaksi/tambah → /transaksi/tambah_transaksi.php
RewriteRule ^transaksi/tambah/?$ transaksi/tambah_transaksi.php [L,QSA]

# /transaksi/edit/5 → /transaksi/edit_transaksi.php?id=5
RewriteRule ^transaksi/edit/([0-9]+)/?$ transaksi/edit_transaksi.php?id=$1 [L,QSA]

# /piutang → /piutang/piutang.php
RewriteRule ^piutang/?$          piutang/piutang.php      [L,QSA]

# /hutang → /piutang/piutang.php (alias)
RewriteRule ^hutang/?$           piutang/piutang.php      [L,QSA]

# Jika pakai ?page=xxx dari index.php
# /index.php?page=pembeli sudah jalan otomatis
